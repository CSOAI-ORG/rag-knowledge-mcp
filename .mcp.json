{
  "name": "rag-knowledge-mcp",
  "description": "MCP server for rag knowledge. Features semantic search, knowledge graph query, index document. From MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "semantic_search",
      "description": "Semantic search over indexed documents.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "top_k": {
            "type": "integer"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "knowledge_graph_query",
      "description": "Query the knowledge graph by entity and optional relation.",
      "parameters": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          }
        },
        "required": [
          "entity"
        ]
      }
    },
    {
      "name": "index_document",
      "description": "Index a document into vector store and knowledge graph.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "doc_id": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "text"
        ]
      }
    },
    {
      "name": "extract_entities_tool",
      "description": "Extract regulatory entities from text.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "cross_reference",
      "description": "Find cross-references between two frameworks for a term.",
      "parameters": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          },
          "framework_a": {
            "type": "string"
          },
          "framework_b": {
            "type": "string"
          }
        },
        "required": [
          "term",
          "framework_a",
          "framework_b"
        ]
      }
    }
  ]
}